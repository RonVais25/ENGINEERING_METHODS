# GoNature server configuration template.
#
# To use:
#   1. Copy this file to `.env` (in the same folder).
#   2. Replace YOUR_PASSWORD_HERE with your local MySQL root password.
#
# `.env` is gitignored, so your real password will never be committed.
DB_PASSWORD=YOUR_PASSWORD_HERE

# Scheduler thresholds (read by server.scheduler.SchedulerConfig). Optional — the
# defaults below are also baked into the code. These are the real production
# values; shrink them for the live demo and restart, e.g. GRAB_WINDOW_MINUTES=1
# and SCHEDULER_POLL_SECONDS=10, so an offered grab lapses in a minute.
REMINDER_LEAD_HOURS=24
CONFIRM_TIMEOUT_MINUTES=120
GRAB_WINDOW_MINUTES=60
SCHEDULER_POLL_SECONDS=30
