# GoNature server configuration template.
#
# To use:
#   1. Copy this file to `.env` (in the same folder).
#   2. Replace YOUR_PASSWORD_HERE with your local MySQL root password.
#
# `.env` is gitignored, so your real password will never be committed.
DB_PASSWORD=YOUR_PASSWORD_HERE

# Scheduler thresholds (read by server.scheduler.SchedulerConfig). Optional — the
# defaults below are also baked into the code. To switch modes: comment out one
# block, uncomment the other, then restart the server (only one active at a time).

# ── REAL / production defaults (active) ─────────────────────────────────────
REMINDER_LEAD_HOURS=24
CONFIRM_TIMEOUT_MINUTES=120
GRAB_WINDOW_MINUTES=60
SCHEDULER_POLL_SECONDS=30

# ── DEMO / live-defense values (uncomment this block, comment the one above) ─
# REMINDER_LEAD_HOURS=720
# CONFIRM_TIMEOUT_MINUTES=1
# GRAB_WINDOW_MINUTES=1
# SCHEDULER_POLL_SECONDS=10
