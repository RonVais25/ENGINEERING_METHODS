<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Cancellations report (DEPT_MANAGER only): a per-day line chart of cancelled /
     no-show reservations over a date range and (optionally) one park, with a small
     totals + average-per-day summary line. Two trend lines (Cancelled / No-show)
     with a dot marking each day's count. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.CancellationsReportController"
            fitToWidth="true" fitToHeight="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" spacing="12">

        <!-- Filter row: date range + park-or-all + Generate. -->
        <VBox styleClass="card" spacing="12">
            <Label text="CANCELLATIONS &amp; NO-SHOWS" styleClass="section-label"/>
            <HBox spacing="14" alignment="BOTTOM_LEFT">
                <VBox spacing="6">
                    <Label text="From" styleClass="field-label"/>
                    <DatePicker fx:id="fromPicker" promptText="dd / mm / yyyy" styleClass="date-picker" prefHeight="42"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="To" styleClass="field-label"/>
                    <DatePicker fx:id="toPicker" promptText="dd / mm / yyyy" styleClass="date-picker" prefHeight="42"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Park" styleClass="field-label"/>
                    <ComboBox fx:id="parkCombo" prefWidth="180" prefHeight="42" styleClass="input-field"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- minWidth=-Infinity (USE_PREF_SIZE): never let the action button shrink
                     below its label into "Ge.." when the filter row gets tight. -->
                <Button fx:id="generateBtn" text="Generate" onAction="#onGenerate"
                        styleClass="btn-primary" minWidth="-Infinity"/>
            </HBox>
            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>

        <!-- Per-day chart + range-summary line. Two trend lines per date:
             "Cancelled" and "No-show", each with a dot at every day's count. -->
        <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
            <Label fx:id="cardHeaderLabel" text="CANCELLATIONS &amp; NO-SHOWS" styleClass="section-label"/>
            <LineChart fx:id="chart" animated="false" createSymbols="true" prefHeight="320"
                       styleClass="report-chart" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis fx:id="xAxis" label="Date" tickLabelRotation="-90"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="yAxis" label="Number of cancellations"/>
                </yAxis>
            </LineChart>
            <!-- Shown instead of an empty chart when the range has no activity. -->
            <VBox fx:id="placeholderBox" styleClass="result-empty" visible="false" managed="false">
                <Label text="No cancellations in this range." styleClass="result-empty-msg"/>
            </VBox>
            <Label fx:id="summaryLabel" styleClass="stat-tile-sub"/>
        </VBox>
    </VBox>
</ScrollPane>
