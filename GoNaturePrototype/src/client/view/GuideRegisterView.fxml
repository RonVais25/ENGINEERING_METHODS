<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a ScrollPane (same pattern as ReservationCreateView) so the form
     scrolls when it doesn't fit the content area instead of being clipped. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.GuideRegisterController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" alignment="TOP_CENTER">

        <VBox styleClass="card" maxWidth="520" spacing="16">

            <Label text="REGISTER GUIDE" styleClass="section-label"/>

            <Label text="National ID" styleClass="field-label"/>
            <TextField fx:id="idField" promptText="National ID (e.g. 200000006)"
                       styleClass="input-field"/>

            <Label text="Full Name" styleClass="field-label"/>
            <TextField fx:id="nameField" promptText="Guide's full name"
                       styleClass="input-field"/>

            <Label text="Phone" styleClass="field-label"/>
            <TextField fx:id="phoneField" promptText="050-1234567"
                       styleClass="input-field"/>

            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="name@example.com"
                       styleClass="input-field"/>

            <!-- Home park: informational (shown, not used to restrict which park the
                 guide may later book). Populated from the server's park list. -->
            <Label text="Home Park" styleClass="field-label"/>
            <ComboBox fx:id="parkCombo" maxWidth="Infinity" styleClass="input-field"
                      promptText="Select the guide's home park"/>

            <Button fx:id="registerBtn" text="✚  Register Guide" onAction="#onRegister"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>
    </VBox>
</ScrollPane>
