<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a ScrollPane (same pattern as HistoryView) so the tall form
     scrolls when it doesn't fit the content area instead of being clipped. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.ReservationCreateController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" alignment="TOP_CENTER">

        <VBox styleClass="card" maxWidth="520" spacing="16">

            <Label text="NEW RESERVATION" styleClass="section-label"/>

            <Label text="Park" styleClass="field-label"/>
            <ComboBox fx:id="parkCombo" maxWidth="Infinity" styleClass="input-field"/>

            <Label text="Visitor ID" styleClass="field-label"/>
            <TextField fx:id="visitorField" promptText="National ID (e.g. 200000001)"
                       styleClass="input-field"/>

            <Label text="Visit Date" styleClass="field-label"/>
            <DatePicker fx:id="datePicker" maxWidth="Infinity"
                        promptText="dd / mm / yyyy" styleClass="date-picker"/>

            <Label text="Visit Time (optional)" styleClass="field-label"/>
            <TextField fx:id="timeField" promptText="HH:mm — leave blank for no preference"
                       styleClass="input-field"/>

            <Label text="Party Size" styleClass="field-label"/>
            <Spinner fx:id="partySpinner" editable="true" maxWidth="Infinity" styleClass="spinner"/>

            <Label text="Visit Type" styleClass="field-label"/>
            <ComboBox fx:id="typeCombo" maxWidth="Infinity" styleClass="input-field"/>

            <Button fx:id="bookBtn" text="+  Book Visit" onAction="#onBook"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>
    </VBox>
</ScrollPane>
