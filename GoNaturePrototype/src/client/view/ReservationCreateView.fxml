<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a ScrollPane so the tall form scrolls when it doesn't fit the
     content area instead of being clipped. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.ReservationCreateController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" alignment="TOP_CENTER">

        <VBox styleClass="card" maxWidth="560" spacing="14">

            <Label text="NEW RESERVATION" styleClass="section-label"/>

            <!-- Row 1: Park + Visitor ID (50 / 50) -->
            <HBox spacing="16" alignment="TOP_LEFT">
                <VBox spacing="6" prefWidth="100" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <Label text="Park" styleClass="field-label"/>
                    <ComboBox fx:id="parkCombo" maxWidth="Infinity" styleClass="input-field"/>
                </VBox>
                <VBox spacing="6" prefWidth="100" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <Label text="Visitor ID" styleClass="field-label"/>
                    <TextField fx:id="visitorField" promptText="National ID (e.g. 200000001)"
                               maxWidth="Infinity" styleClass="input-field"/>
                </VBox>
            </HBox>

            <!-- Row 2: Email + Phone (50 / 50). Both required (email is the booking's
                 notification target); both prefill from a logged-in visitor's record. -->
            <HBox spacing="16" alignment="TOP_LEFT">
                <VBox spacing="6" prefWidth="100" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <Label text="Email" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="name@example.com (required)"
                               maxWidth="Infinity" styleClass="input-field"/>
                </VBox>
                <VBox spacing="6" prefWidth="100" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <Label text="Phone" styleClass="field-label"/>
                    <TextField fx:id="phoneField" promptText="e.g. 050-1234567 (at least 10 digits)"
                               maxWidth="Infinity" styleClass="input-field"/>
                </VBox>
            </HBox>

            <!-- Row 3: Visit Date + Visit Time (50 / 50). The time control is a 12-hour
                 picker built from three plain dropdowns (Hour : Minute + AM/PM) gated by
                 "set time" — left unticked it sends no preferred time (null visitTime),
                 exactly like the old blank field. The three combos share the row's right
                 half evenly so AM/PM stays clearly readable. The controller converts the
                 12-hour selection to the 24-hour HH:mm:ss wire format the server/DB
                 expect. -->
            <HBox spacing="16" alignment="TOP_LEFT">
                <VBox spacing="6" prefWidth="100" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <Label text="Visit Date" styleClass="field-label"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                promptText="dd / mm / yyyy" styleClass="date-picker"/>
                </VBox>
                <VBox spacing="6" prefWidth="100" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Visit Time" styleClass="field-label"/>
                        <CheckBox fx:id="timeEnabledCheck" text="set time" styleClass="check-field"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT" styleClass="time-row">
                        <ComboBox fx:id="hourCombo"   maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                  styleClass="input-field time-combo"/>
                        <Label text=":" styleClass="time-colon"/>
                        <ComboBox fx:id="minuteCombo" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                  styleClass="input-field time-combo"/>
                        <ComboBox fx:id="ampmCombo"   maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                  styleClass="input-field time-combo"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Row 4: Visit Type + Party Size (70 / 30) -->
            <GridPane hgap="16">
                <columnConstraints>
                    <ColumnConstraints percentWidth="70"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0">
                    <Label text="Visit Type" styleClass="field-label"/>
                    <ComboBox fx:id="typeCombo" maxWidth="Infinity" styleClass="input-field"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="1">
                    <Label text="Party Size" styleClass="field-label"/>
                    <Spinner fx:id="partySpinner" editable="true" maxWidth="Infinity" styleClass="spinner"/>
                </VBox>
            </GridPane>

            <!-- Conditional guide field: only shown (and required) for GROUP visits. -->
            <VBox fx:id="guideRow" spacing="6" visible="false" managed="false">
                <Label text="Guide ID (groups, max 15)" styleClass="field-label"/>
                <TextField fx:id="guideField" promptText="Registered guide's national ID (e.g. 200000003)"
                           maxWidth="Infinity" styleClass="input-field"/>
            </VBox>

            <!-- Paying up front deepens the group discount; the server records it
                 on the reservation (paid_in_advance) and reflects it in the price. -->
            <CheckBox fx:id="prePayCheck" text="Pay in advance" styleClass="check-field"/>

            <Button fx:id="bookBtn" text="+  Book Visit" onAction="#onBook"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>

            <!-- Payment confirmation, populated from the server's reservation DTO
                 on a successful booking (see ReservationCreateController#onBook). -->
            <VBox fx:id="confirmationBox" styleClass="payment-card" spacing="8"
                  visible="false" managed="false"/>
        </VBox>
    </VBox>
</ScrollPane>
