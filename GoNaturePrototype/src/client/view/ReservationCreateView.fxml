<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a ScrollPane so the tall form scrolls when it doesn't fit the
     content area instead of being clipped. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.ReservationCreateController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" alignment="TOP_CENTER">

        <VBox styleClass="card" maxWidth="520" spacing="16">

            <Label text="NEW RESERVATION" styleClass="section-label"/>

            <Label text="Park" styleClass="field-label"/>
            <ComboBox fx:id="parkCombo" maxWidth="Infinity" styleClass="input-field"/>

            <Label text="Visitor ID" styleClass="field-label"/>
            <TextField fx:id="visitorField" promptText="National ID (e.g. 200000001)"
                       styleClass="input-field"/>

            <!-- Contact: email and phone are both required (email is the booking's
                 notification target). Both prefill from a logged-in visitor's record. -->
            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="name@example.com (required)"
                       styleClass="input-field"/>

            <Label text="Phone" styleClass="field-label"/>
            <TextField fx:id="phoneField" promptText="e.g. 050-1234567 (at least 10 digits)"
                       styleClass="input-field"/>

            <Label text="Visit Date" styleClass="field-label"/>
            <DatePicker fx:id="datePicker" maxWidth="Infinity"
                        promptText="dd / mm / yyyy" styleClass="date-picker"/>

            <!-- Clock-style time picker: an hour:minute Spinner pair. Optional —
                 the "Set a time" toggle gates it; left unchecked it sends no
                 preferred time (null visitTime), exactly like the old blank field. -->
            <Label text="Visit Time (optional)" styleClass="field-label"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <CheckBox fx:id="timeEnabledCheck" text="Set a time" styleClass="check-field"/>
                <Spinner fx:id="hourSpinner"   styleClass="spinner"/>
                <Label text=":" styleClass="field-label"/>
                <Spinner fx:id="minuteSpinner" styleClass="spinner"/>
            </HBox>

            <Label text="Party Size" styleClass="field-label"/>
            <Spinner fx:id="partySpinner" editable="true" maxWidth="Infinity" styleClass="spinner"/>

            <Label text="Visit Type" styleClass="field-label"/>
            <ComboBox fx:id="typeCombo" maxWidth="Infinity" styleClass="input-field"/>

            <!-- Guide ID: only shown (and required) for GROUP visits. -->
            <Label fx:id="guideLabel" text="Guide ID (groups, max 15)" styleClass="field-label"
                   visible="false" managed="false"/>
            <TextField fx:id="guideField" promptText="Registered guide's national ID (e.g. 200000003)"
                       styleClass="input-field" visible="false" managed="false"/>

            <!-- Paying up front deepens the group discount; the server records it
                 on the reservation (paid_in_advance) and reflects it in the price. -->
            <CheckBox fx:id="prePayCheck" text="Pay in advance" styleClass="check-field"/>

            <Button fx:id="bookBtn" text="+  Book Visit" onAction="#onBook"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>

            <!-- Payment confirmation, populated from the server's reservation DTO
                 on a successful booking (see ReservationCreateController#onBook). -->
            <VBox fx:id="confirmationBox" styleClass="payment-card" spacing="8"
                  visible="false" managed="false"/>
        </VBox>
    </VBox>
</ScrollPane>
