<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Notification center (any logged-in actor): lists the actor's notifications
     newest-first, highlights unread ones, and acknowledges them. Same ScrollPane
     + history-table pattern as ApprovalQueueView. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.NotificationCenterController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" spacing="12">

        <VBox styleClass="card" spacing="12">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="NOTIFICATIONS" styleClass="section-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshBtn" text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
            </HBox>
            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>

        <VBox styleClass="history-card" VBox.vgrow="ALWAYS">
            <HBox styleClass="history-card-header">
                <Label fx:id="cardHeaderLabel" text="YOUR NOTIFICATIONS" styleClass="section-label"/>
            </HBox>
            <VBox fx:id="tableBox" spacing="0"/>
        </VBox>
    </VBox>
</ScrollPane>
