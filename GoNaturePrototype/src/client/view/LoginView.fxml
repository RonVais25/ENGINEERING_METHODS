<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.view.LoginController"
      spacing="10" styleClass="login-form">

    <Label text="Connect to Server" styleClass="login-title"/>

    <Label text="Server Host" styleClass="field-label"/>
    <TextField fx:id="hostField" text="localhost" styleClass="input-field"/>

    <Label text="Port" styleClass="field-label"/>
    <TextField fx:id="portField" text="5555" styleClass="input-field"/>

    <Button fx:id="connectBtn" text="→  Connect" styleClass="btn-primary"
            onAction="#onConnect" maxWidth="Infinity"/>

    <Label fx:id="errorLabel" styleClass="login-error" wrapText="true"
           visible="false" managed="false"/>
</VBox>
