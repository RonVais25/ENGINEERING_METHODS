<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Park gate (PARK_EMPLOYEE only). Live occupancy header + entry / exit /
     casual walk-in. ScrollPane root so the form scrolls when it doesn't fit,
     matching the other screens. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.GateController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" alignment="TOP_CENTER" spacing="12">

        <!-- Live occupancy header -->
        <VBox styleClass="card" maxWidth="560" spacing="6">
            <HBox alignment="CENTER_LEFT">
                <Label text="LIVE OCCUPANCY" styleClass="section-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshBtn" text="↻  Refresh" onAction="#onRefresh"
                        styleClass="btn-secondary"/>
            </HBox>
            <Label fx:id="occupancyValue" text="—" styleClass="stat-card-value"/>
            <Label fx:id="occupancySub" text="Loading…" styleClass="stat-card-sub"/>
        </VBox>

        <!-- Entry by reservation -->
        <VBox styleClass="card" maxWidth="560" spacing="14">
            <Label text="ENTRY — BY RESERVATION" styleClass="section-label"/>

            <Label text="Confirmation Code" styleClass="field-label"/>
            <TextField fx:id="entryCodeField" promptText="e.g. 1234" styleClass="input-field"/>

            <Label text="Visitor ID" styleClass="field-label"/>
            <TextField fx:id="entryVisitorField" promptText="National ID on the booking"
                       styleClass="input-field"/>

            <Button fx:id="entryBtn" text="✓  Admit Visitor" onAction="#onEnter"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="entryResult" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>

        <!-- Exit -->
        <VBox styleClass="card" maxWidth="560" spacing="14">
            <Label text="EXIT" styleClass="section-label"/>
            <Label text="Enter the confirmation code, or the visitor ID." styleClass="hint-text"/>

            <Label text="Confirmation Code" styleClass="field-label"/>
            <TextField fx:id="exitCodeField" promptText="e.g. 1234" styleClass="input-field"/>

            <Label text="Visitor ID" styleClass="field-label"/>
            <TextField fx:id="exitVisitorField" promptText="National ID (if no code)"
                       styleClass="input-field"/>

            <Button fx:id="exitBtn" text="↩  Record Exit" onAction="#onExit"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="exitResult" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>

        <!-- Casual walk-in -->
        <VBox styleClass="card" maxWidth="560" spacing="14">
            <Label text="CASUAL WALK-IN" styleClass="section-label"/>

            <Label text="Party Size" styleClass="field-label"/>
            <Spinner fx:id="casualPartySpinner" editable="true" maxWidth="Infinity" styleClass="spinner"/>

            <Label text="Visit Type" styleClass="field-label"/>
            <ComboBox fx:id="casualTypeCombo" maxWidth="Infinity" styleClass="input-field"/>

            <Label text="Visitor ID (optional)" styleClass="field-label"/>
            <TextField fx:id="casualVisitorField" promptText="Leave blank for an anonymous walk-in"
                       styleClass="input-field"/>

            <Button fx:id="casualBtn" text="✦  Admit Walk-in" onAction="#onCasual"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Label fx:id="casualResult" styleClass="toast" visible="false" managed="false" wrapText="true"/>

            <VBox fx:id="casualConfirmBox" styleClass="payment-card" spacing="8"
                  visible="false" managed="false"/>
        </VBox>
    </VBox>
</ScrollPane>
