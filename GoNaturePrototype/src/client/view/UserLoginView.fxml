<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Combined connect + sign-in screen: shown on the main stage at startup and
     again after logout. It collects the server host/port together with the
     credentials in one step — submit PING-probes the server, then sends
     LOGIN_STAFF or LOGIN_VISITOR. A Staff / Visitor segmented toggle swaps the
     credential field set. Styled entirely via client.css. -->
<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="client.view.UserLoginController"
           styleClass="app-root" alignment="CENTER">

    <VBox styleClass="card" alignment="TOP_CENTER" spacing="14"
          maxWidth="360" maxHeight="-Infinity">

        <Label text="GoNature" styleClass="login-title"/>
        <Label text="Connect and sign in to continue" styleClass="hint-text"/>

        <!-- Server: host + port. Disabled once connected (a re-login after logout
             reuses the live connection); the controller fills these in then. -->
        <HBox spacing="10" maxWidth="Infinity">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Server Host" styleClass="field-label"/>
                <TextField fx:id="hostField" text="localhost" styleClass="input-field"/>
            </VBox>
            <VBox spacing="8" maxWidth="96">
                <Label text="Port" styleClass="field-label"/>
                <TextField fx:id="portField" text="5555" styleClass="input-field" prefWidth="90"/>
            </VBox>
        </HBox>

        <!-- Staff / Visitor segmented toggle -->
        <HBox styleClass="seg-group" maxWidth="Infinity">
            <ToggleButton fx:id="staffTab"   text="Staff"   styleClass="seg-btn"
                          maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <ToggleButton fx:id="visitorTab" text="Visitor" styleClass="seg-btn"
                          maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Staff: username + password -->
        <VBox fx:id="staffPane" spacing="8" maxWidth="Infinity">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="e.g. dept_mgr" styleClass="input-field"/>
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>
        </VBox>

        <!-- Visitor: national ID + password -->
        <VBox fx:id="visitorPane" spacing="8" maxWidth="Infinity" visible="false" managed="false">
            <Label text="National ID" styleClass="field-label"/>
            <TextField fx:id="visitorIdField" promptText="e.g. 200000001" styleClass="input-field"/>
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="visitorPasswordField" promptText="Password" styleClass="input-field"/>
        </VBox>

        <Button fx:id="submitBtn" text="Sign In" onAction="#onSubmit"
                styleClass="btn-primary" maxWidth="Infinity"/>

        <!-- New visitors self-register here (creates a regular, non-subscriber
             account; the service rep still owns the subscriber path). -->
        <Button fx:id="registerBtn" text="New visitor? Create an account" onAction="#onRegister"
                styleClass="btn-secondary" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" styleClass="login-error" wrapText="true"
               visible="false" managed="false"/>

        <!-- Dev-only one-click logins for the seeded accounts (pw: changeme).
             Hidden unless UserLoginController.DEBUG_QUICK_LOGIN is flipped on;
             defaults to off so graders never see one-click role switching. -->
        <Label fx:id="quickLoginLabel" text="Quick login · dev" styleClass="quick-label"
               visible="false" managed="false"/>
        <FlowPane fx:id="quickLoginBox" styleClass="quick-row" hgap="6" vgap="6"
                  maxWidth="Infinity" visible="false" managed="false"/>
    </VBox>
</StackPane>
