<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<!-- Promotions editor (PARK_MANAGER only). Define a temporary discount for your
     own park, submitted PENDING for department-manager approval, alongside a live
     list of your promotions with their status.

     Two columns: the CREATE A PROMOTION form on the left, MY PROMOTIONS on the
     right, so both are visible without scrolling the page. Each column is its own
     ScrollPane, so a long list (or a short window) scrolls that column alone — the
     page itself never scrolls. The list gets the wider share because its rows are
     wider than the form's fields; on a narrow window the columns simply shrink. -->
<GridPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
          fx:controller="client.view.PromotionsController"
          styleClass="screen-padded" hgap="20">
    <columnConstraints>
        <ColumnConstraints percentWidth="40" hgrow="ALWAYS"/>
        <ColumnConstraints percentWidth="60" hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>

    <!-- LEFT column: define a promotion -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                GridPane.columnIndex="0" GridPane.rowIndex="0">
        <VBox alignment="TOP_CENTER">
            <VBox styleClass="card" maxWidth="460" spacing="14">
                <Label text="CREATE A PROMOTION" styleClass="section-label"/>

                <VBox styleClass="payment-card" spacing="8">
                    <Label fx:id="parkNameLabel" text="Loading…" styleClass="payment-title"/>
                    <Label text="An approved promotion that is active on the visit date gives an extra discount on this park's visits."
                           styleClass="card-note" wrapText="true"/>
                </VBox>

                <Label text="Name" styleClass="field-label"/>
                <TextField fx:id="nameField" promptText="e.g. Summer Special" styleClass="input-field"/>

                <Label text="Discount ( % )" styleClass="field-label"/>
                <TextField fx:id="percentField" promptText="e.g. 20" styleClass="input-field"/>

                <Label text="Start Date" styleClass="field-label"/>
                <DatePicker fx:id="startPicker" maxWidth="Infinity"
                            promptText="dd / mm / yyyy" styleClass="date-picker"/>

                <Label text="End Date" styleClass="field-label"/>
                <DatePicker fx:id="endPicker" maxWidth="Infinity"
                            promptText="dd / mm / yyyy" styleClass="date-picker"/>

                <Button fx:id="submitBtn" text="Submit for Approval" onAction="#onSubmit"
                        styleClass="btn-primary" maxWidth="Infinity"/>

                <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- RIGHT column: the manager's own promotions, all statuses -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                GridPane.columnIndex="1" GridPane.rowIndex="0">
        <VBox alignment="TOP_CENTER">
            <VBox styleClass="history-card" maxWidth="720">
                <HBox styleClass="history-card-header" alignment="CENTER_LEFT">
                    <Label fx:id="listHeaderLabel" text="MY PROMOTIONS" styleClass="section-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="refreshBtn" text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
                </HBox>
                <VBox fx:id="promotionsBox" spacing="0">
                    <HBox styleClass="history-row">
                        <Label text="Loading your promotions…" styleClass="history-cell muted"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</GridPane>
