<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.DashboardController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded">

        <!-- Stat cards row — three equal cells, populated by the controller -->
        <HBox fx:id="statsRow" spacing="14"/>

        <!-- Recent orders card -->
        <VBox fx:id="recentCard" styleClass="card" VBox.vgrow="ALWAYS">
            <Label text="RECENT ORDERS" styleClass="section-label"/>
            <VBox fx:id="recentList" spacing="0"/>
        </VBox>
    </VBox>
</ScrollPane>
