<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Visits-by-Type report (DEPT_MANAGER only): a bar chart of visit counts for
     Individuals vs Organized groups over a date range and (optionally) one park,
     with per-category average-stay summary tiles. -->
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.VisitsReportController"
            fitToWidth="true" fitToHeight="true" styleClass="scroll-pane">

    <VBox styleClass="screen-padded" spacing="12">

        <!-- Filter row: date range + park-or-all + Generate. -->
        <VBox styleClass="card" spacing="12">
            <Label text="VISITS BY TYPE" styleClass="section-label"/>
            <HBox spacing="14" alignment="BOTTOM_LEFT">
                <VBox spacing="6">
                    <Label text="From" styleClass="field-label"/>
                    <DatePicker fx:id="fromPicker" promptText="dd / mm / yyyy" styleClass="date-picker"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="To" styleClass="field-label"/>
                    <DatePicker fx:id="toPicker" promptText="dd / mm / yyyy" styleClass="date-picker"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Park" styleClass="field-label"/>
                    <ComboBox fx:id="parkCombo" prefWidth="180" styleClass="input-field"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="generateBtn" text="Generate" onAction="#onGenerate" styleClass="btn-primary"/>
            </HBox>
            <Label fx:id="resultLabel" styleClass="toast" visible="false" managed="false" wrapText="true"/>
        </VBox>

        <!-- Chart + per-category summary tiles. -->
        <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
            <Label text="VISITS — INDIVIDUALS vs ORGANIZED GROUPS" styleClass="section-label"/>
            <BarChart fx:id="chart" legendVisible="false" animated="false"
                      prefHeight="320" styleClass="report-chart" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis fx:id="xAxis" label="Visitor category"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="yAxis" label="Number of visits"/>
                </yAxis>
            </BarChart>
            <HBox fx:id="summaryBox" spacing="12"/>
        </VBox>
    </VBox>
</ScrollPane>
